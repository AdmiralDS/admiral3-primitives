{
  "name": "@admiral-ds/admiral3-primitives",
  "version": "0.0.0",
  "description": "React component library for Admiral design system 3.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "AdmiralDS",
    "Admiral",
    "ui",
    "react",
    "library"
  ],
  "author": "Admiral DS team",
  "license": "See license in ./LICENSE",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "check:fix": "npm run format && npm run lint:fix",
    "check:full": "npm run format:check && npm run lint && npm run validate:components && npm run typecheck && npm run test:run && npm run test:e2e",
    "storybook": "storybook dev -p 6006",
    "playground": "vite --config vite.playground.config.ts",
    "generate:component": "node scripts/generate-react-component.mjs",
    "validate:components": "node scripts/validate-components.mjs",
    "release": "standard-version",
    "build": "vite build && tsc -p tsconfig.lib.json",
    "storybook:build": "storybook build",
    "playground:build": "vite build --config vite.playground.config.ts",
    "playground:serve": "serve -s dist-playground -l 4173",
    "pack:check": "node scripts/validate-package.mjs",
    "test:e2e": "npm run build && npm run playground:build && playwright test",
    "test:e2e-ui": "npm run build && npm run playground:build && playwright test --ui",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -b tsconfig.json",
    "dev": "vite"
  },
  "peerDependencies": {
    "@admiral-ds/admiral3-icons": "~0.0.1",
    "@admiral-ds/admiral3-tokens": "~0.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@admiral-ds/admiral3-icons": "~0.0.1",
    "@admiral-ds/admiral3-tokens": "~0.0.2",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.3",
    "generate-react-cli": "^11.0.4",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "3.8.1",
    "serve": "^14.2.5",
    "standard-version": "^9.5.0",
    "storybook": "^10.3.3",
    "styled-components": "^6.4.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.2"
  },
  "repository": "https://github.com/AdmiralDS/admiral3-primitives",
  "bugs": {
    "url": "https://github.com/AdmiralDS/admiral3-primitives/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
